    "@ossintel/scoring": "workspace:*",
    "@ossintel/stackoverflow": "workspace:*",
    "@promptshield/tiptap": "latest",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tool/scripts": "workspace:*",
    "@turboforge/cli-kit": "latest",
    "@turboforge/remark-typedoc-mdx": "latest",
