{
  "name": "@ossintel/input-parser",
  "author": "Mayank Kumar Chaudhari <https://mayankchaudhari.com>",
  "private": false,
  "version": "0.2.1",
  "description": "Lightweight and extensible input query parser for resolving developer, repository, organization, and package paths across multiple ecosystems (GitHub, NPM, StackOverflow, VS Code).",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ossintel/ossintel",
    "directory": "packages/input-parser"
  },
  "bugs": "https://github.com/ossintel/ossintel/issues",
  "homepage": "https://github.com/ossintel/ossintel/blob/main/packages/input-parser/README.md",
  "sideEffects": false,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup && gzip -c dist/index.js | wc -c",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "latest"
  },
  "forge": {
    "aliases": [],
    "icon": "LibraryBig",
    "description": "Extensible input query parser"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ossintel"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/mayank1513"
    }
  ],
  "keywords": [
    "ossintel",
    "parser",
    "input-detection",
    "github",
    "npm",
    "stackoverflow",
    "vscode",
    "monorepo"
  ]
}
