{
  "name": "@ossintel/insights",
  "author": "Mayank Kumar Chaudhari <https://mayankchaudhari.com>",
  "private": false,
  "version": "0.1.0",
  "description": "Rule-based insight generation engine for open-source software audit, producing findings, risk mitigation plans, and prompt contexts.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mayank1513/ossintel",
    "directory": "packages/insights"
  },
  "bugs": "https://github.com/mayank1513/ossintel/issues",
  "homepage": "https://github.com/mayank1513/ossintel/blob/main/packages/insights/README.md",
  "sideEffects": false,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup && gzip -c dist/index.js | wc -c",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@ossintel/github-normalizer": "workspace:*",
    "@ossintel/npm": "workspace:*",
    "@ossintel/scoring": "workspace:*",
    "@ossintel/stackoverflow": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "^6.0.3"
  },
  "forge": {
    "aliases": [],
    "icon": "LibraryBig",
    "description": ""
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mayank1513"
    }
  ],
  "keywords": [
    "oss-insights",
    "code-audits",
    "risk-assessment",
    "open-source-health",
    "findings",
    "recommendations",
    "analytics-engine",
    "turboforge"
  ]
}
