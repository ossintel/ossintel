{
  "name": "@ossintel/npm",
  "author": "Mayank Kumar Chaudhari <https://mayankchaudhari.com>",
  "private": false,
  "version": "0.0.1",
  "description": "Robust, typed utilities to fetch, normalize, and sanitize raw npm Registry and download statistics API responses into consistent domain structures for open-source analytics.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mayank1513/ossintel",
    "directory": "packages/npm"
  },
  "bugs": "https://github.com/mayank1513/ossintel/issues",
  "homepage": "https://github.com/mayank1513/ossintel/blob/main/packages/npm/README.md",
  "sideEffects": false,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup && gzip -c dist/index.js | wc -c",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "^6.0.3"
  },
  "forge": {
    "aliases": [],
    "icon": "Package",
    "description": "NPM registry statistics fetcher"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mayank1513"
    }
  ],
  "keywords": [
    "npm-registry",
    "npm-downloads",
    "data-normalization",
    "open-source",
    "analytics",
    "ossintel",
    "typescript",
    "fetch",
    "turboforge"
  ]
}
