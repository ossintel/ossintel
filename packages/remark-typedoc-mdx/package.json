{
  "name": "@turboforge/remark-typedoc-mdx",
  "author": "Mayank Kumar Chaudhari <https://mayankchaudhari.com>",
  "private": false,
  "version": "0.1.0",
  "description": "Remark plugin to transform and sanitize TypeDoc generated markdown for seamless MDX integration.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/turboforge-dev/turboforge",
    "directory": "packages/remark-typedoc-mdx"
  },
  "bugs": "https://github.com/turboforge-dev/turboforge/issues",
  "homepage": "https://github.com/turboforge-dev/turboforge/blob/main/packages/remark-typedoc-mdx/README.md",
  "sideEffects": false,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "^7.0.2",
    "unified": "^11.0.5"
  },
  "forge": {
    "aliases": [
      "remark-typedoc-mdx"
    ],
    "icon": "Terminal",
    "description": "TypeDoc to MDX Plugin"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/turboforge-dev"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/mayank1513"
    }
  ],
  "keywords": [
    "remark",
    "typedoc",
    "mdx",
    "ast",
    "mdast",
    "documentation",
    "unified",
    "markdown-plugin",
    "typescript"
  ],
  "dependencies": {
    "unist-util-visit": "^5.1.0"
  }
}
