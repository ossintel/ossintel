{
  "name": "@ossintel/stackoverflow",
  "author": "Mayank Kumar Chaudhari <https://mayankchaudhari.com>",
  "private": false,
  "version": "0.0.2",
  "description": "Robust, typed utilities to fetch, normalize, and sanitize StackOverflow user profiles, reputation, badges, and top tag statistics from the StackExchange API.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ossintel/ossintel",
    "directory": "packages/stackoverflow"
  },
  "bugs": "https://github.com/ossintel/ossintel/issues",
  "homepage": "https://github.com/ossintel/ossintel/blob/main/packages/stackoverflow/README.md",
  "sideEffects": false,
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup && gzip -c dist/index.js | wc -c",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "^6.0.3"
  },
  "forge": {
    "aliases": [],
    "icon": "MessageSquare",
    "description": "StackOverflow profile statistics fetcher"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mayank1513"
    }
  ],
  "keywords": [
    "stackoverflow-api",
    "stackexchange",
    "data-normalization",
    "open-source",
    "analytics",
    "ossintel",
    "typescript",
    "fetch",
    "turboforge"
  ]
}
