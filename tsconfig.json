{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* Base Standards */
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["node"],

    /* Module Resolution */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* Strictness */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,

    /* Path Mapping */
    "paths": {
      "@turboforge/cli-kit": [
        "./packages/cli-kit/src",
        "./packages/cli-kit/dist"
      ],
      "@turboforge/remark-typedoc-mdx": [
        "./packages/remark-typedoc-mdx/src",
        "./packages/remark-typedoc-mdx/dist"
      ],
      "@turboforge/sync": [
        "./packages/forge-sync/src",
        "./packages/forge-sync/dist"
      ]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", "vitest.config.ts"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.turbo",
    "apps",
    "examples",
    "coverage"
  ]
}
